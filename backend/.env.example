PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/medilink?retryWrites=true&w=majority

# API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
AI_API_KEY=your_openai_or_gemini_api_key_here

# Payment Gateway (e.g., Razorpay / Stripe)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Video Call API (e.g., Twilio / Agora / Daily.co)
VIDEO_CALL_APP_ID=your_video_call_app_id
